# =====================================================================
# Voter Platform — environment template. Copy to `.env` and fill in.
# NEVER commit a real .env. Secrets live in Vercel/Railway/GitHub.
# =====================================================================

NODE_ENV=development

# --- Postgres (Neon) -------------------------------------------------
# Pooled PgBouncer host (-pooler:6432, transaction mode) — the APP query path.
DATABASE_URL="postgresql://neondb_owner:npg_ex3Q8gcDTjpS@ep-raspy-breeze-aitxmdro-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# Direct (non-pooler) host — migrations, DDL, the worker. Required for partition DDL.
DATABASE_URL_DIRECT="postgresql://neondb_owner:npg_ex3Q8gcDTjpS@ep-raspy-breeze-aitxmdro-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# Pooled read replica — analytics / audit / results reads. Never the write primary.
DATABASE_URL_REPLICA="postgresql://neondb_owner:npg_ex3Q8gcDTjpS@ep-raspy-breeze-aitxmdro-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# --- Upstash Redis + QStash -----------------------------------------
UPSTASH_REDIS_REST_URL="https://warm-halibut-155861.upstash.io"
UPSTASH_REDIS_REST_TOKEN="gQAAAAAAAmDVAAIgcDI2OTBhZTllOGFmNzI0ZGIwOWIxYTQyNWMzZDYyNjYwNg"
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# --- Backblaze B2 (S3-compatible) -----------------------------------
B2_S3_ENDPOINT="https://s3.us-east-005.backblazeb2.com"
B2_REGION="us-east-005"
# Read/write key scoped to media + uploads buckets.
B2_KEY_ID="00585f8085ac3f10000000002"
B2_APP_KEY="K005d15fN99UtAg4QbU3hSHcXe9IKfs"
# Separate read-only key used only for download presigning of private exports.
B2_DOWNLOAD_KEY_ID="00585f8085ac3f10000000002"
B2_DOWNLOAD_KEY="K005d15fN99UtAg4QbU3hSHcXe9IKfs"
B2_BUCKET_MEDIA="voter-media"
B2_BUCKET_EXPORTS="voter-exports"
B2_BUCKET_UPLOADS="voter-uploads"

# --- Email / SMS -----------------------------------------------------
RESEND_API_KEY=""              # transactional (OTP email, receipts, security)
RESEND_FROM="Voter <no-reply@mail.example.ng>"
BREVO_API_KEY=""               # bulk campaigns + SMS OTP
BREVO_SMS_SENDER="Voter"

# --- KYC (Nigeria) ---------------------------------------------------
KYC_PROVIDER_PRIMARY="dojah"
KYC_PROVIDER_FALLBACK="smileid"
DOJAH_APP_ID=""
DOJAH_API_KEY=""
DOJAH_WEBHOOK_SECRET=""         # HMAC verify on inbound webhook
SMILEID_PARTNER_ID=""
SMILEID_API_KEY=""
SMILEID_CALLBACK_SECRET=""
# Daily KYC spend circuit-breaker: trip to manual review above N paid verifications/day.
KYC_DAILY_SPEND_CAP="5000"

# --- KMS / HSM (R-D: peppers NEVER live in process.env) --------------
# MAC operations run inside the KMS; the app sends preimage, receives digest.
KMS_PROVIDER="aws"             # aws | gcp | vault | local-dev
KMS_DEDUP_KEY_ID=""            # one-human-one-vote dedup HMAC key
KMS_PHONE_KEY_ID=""            # phone blind-index key
KMS_RECEIPT_KEY_ID=""         # vote receipt MAC key
KMS_RISK_KEY_ID=""            # ip_hmac / fp_hmac key (daily-rotated salt on top)
PEPPER_KEY_VERSION="1"         # bump to rotate; old versions stay valid for verify
# local-dev only fallback pepper (NEVER set in staging/prod):
DEV_LOCAL_PEPPER=""

# --- Auth.js ---------------------------------------------------------
AUTH_SECRET=""                 # openssl rand -base64 32
AUTH_URL="http://localhost:3000"

# --- Cloudflare ------------------------------------------------------
CLOUDFLARE_TURNSTILE_SECRET=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# --- Realtime / Worker ----------------------------------------------
# REALTIME_PROVIDER: "worker" (self-hosted SSE) | "ably" (managed, default for national scale)
REALTIME_PROVIDER="worker"
ABLY_API_KEY=""
NEXT_PUBLIC_ABLY_KEY=""
SSE_WORKER_URL="http://localhost:8080"
NEXT_PUBLIC_STREAM_BASE="http://localhost:8080"
WORKER_SHARED_SECRET=""        # worker <-> api auth

# --- Observability ---------------------------------------------------
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# --- App -------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
VERCEL_REGION="fra1"
